DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_planner
SECRET_KEY=changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ANTHROPIC_API_KEY=

# ── Google Places (optional) ────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
CACHE_TTL_DAYS=30

# ── Itinerary candidate radius ───────────────────────────
# adaptive: 8 km is the compact-city floor, expands up to 20 km for extended cities.
# fixed: use ITINERARY_ACTIVITY_RADIUS_KM exactly, useful for thesis A/B (8 vs 20).
ITINERARY_ACTIVITY_RADIUS_MODE=adaptive
ITINERARY_ACTIVITY_RADIUS_KM=8
ITINERARY_ACTIVITY_RADIUS_TARGET_SHARE=0.85
ITINERARY_ACTIVITY_RADIUS_MIN_POIS_PER_DAY=8

# ── POI Pipeline classifier ──────────────────────────────
# Use Anthropic Haiku for batch POI classification
PIPELINE_LLM_BACKEND=anthropic
PIPELINE_LLM_MODEL=claude-haiku-4-5-20251001

# ── Onboarding (experience discovery with web search) ────
# Use Sonnet + tool use for onboarding
# No longer configurable via .env — hardcoded in onboarding.py
# Works if ANTHROPIC_API_KEY is configured

# ── Cloudflare R2 (optional) ───────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=travel-agent
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Resend (optional) ──────────────────────────────────────
# If missing, email verification is bypassed in dev (user auto-verified)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
