DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_planner
SECRET_KEY=changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_STRUCTURED_OUTPUT=true

# ── Google Places (optional) ────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
CACHE_TTL_DAYS=30

# ── Real travel times (optional) ────────────────────────
# Real road travel times instead of haversine. Master switch (any provider).
ROUTES_API_ENABLED=false
# Provider: "ors" (OpenRouteService, hosted free key, no billing) | "google"
ROUTING_PROVIDER=ors
# OpenRouteService: free key at https://openrouteservice.org/dev (40 req/min, 500/day)
OPENROUTESERVICE_API_KEY=
# Google Routes API (only if ROUTING_PROVIDER=google; needs billing enabled)
# GOOGLE_ROUTES_API_KEY=   # only if using a separate dedicated key

# ── Personalized walking threshold (transport-mode selection) ──────────
# Legs shorter than the walking cut-off walk; longer ones take transit/taxi.
# Personalization scales the base cut-off by age + relax (young/intense walk
# further → more real ORS foot routing; senior/relax switch to transit sooner).
# Set WALK_PERSONALIZATION=false for the fixed-cut-off baseline (thesis A/B).
WALK_PERSONALIZATION=true
WALK_THRESHOLD_BASE_M=800
WALK_THRESHOLD_MIN_M=350
WALK_THRESHOLD_MAX_M=2000
WALK_RELAX_BASE=1.15
WALK_RELAX_SLOPE=0.45

# ── Itinerary solver ─────────────────────────────────────
# greedy: cluster→MMR→greedy baseline
# toptw:  Team Orienteering Problem with Time Windows (OR-Tools)
ITINERARY_SOLVER=toptw

# ── TOPTW pre-clustering (thesis ablation) ──────────────
# off: global TOPTW (A/B arm / baseline)
# on:  always pre-cluster (A/B arm)
# auto: pre-cluster only when day-clusters are geographically balanced (default)
TOPTW_PRE_CLUSTER_MODE=auto
# Intra-day outlier pruning (only when pre-cluster is ON): drop a non-iconic POI whose
# nearest same-day neighbour is farther than the threshold, so one stray park/site
# doesn't inflate the day. true/false; lower max_nn = more aggressive.
TOPTW_PRUNE_OUTLIERS=true
TOPTW_CLUSTER_OUTLIER_MAX_NN_M=1500
# Pre-cluster on the full activity pool (like the greedy baseline) → cleaner day-zones,
# less zigzag. false = cluster only the prize-filtered top-N (older behaviour).
TOPTW_CLUSTER_FULL_POOL=true

# ── Itinerary candidate radius ───────────────────────────
# adaptive: 8 km is the compact-city floor, expands up to 20 km for extended cities.
# fixed: use ITINERARY_ACTIVITY_RADIUS_KM exactly, useful for thesis A/B (8 vs 20).
ITINERARY_ACTIVITY_RADIUS_MODE=adaptive
ITINERARY_ACTIVITY_RADIUS_KM=8
ITINERARY_ACTIVITY_RADIUS_TARGET_SHARE=0.85
ITINERARY_ACTIVITY_RADIUS_MIN_POIS_PER_DAY=8

# ── POI Pipeline classifier ──────────────────────────────
# backend: openai | anthropic
PIPELINE_LLM_BACKEND=openai
PIPELINE_LLM_MODEL=gpt-5.4-mini
# Reasoning effort for OpenAI reasoning models (none | low | medium | high). Ignored by Anthropic.
PIPELINE_REASONING_EFFORT=none
# Set to true to print per-POI debug lines to console
PIPELINE_VERBOSE=true

# ── Cloudflare R2 (optional) ───────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=travel-agent
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Resend (optional) ──────────────────────────────────────
# If missing, email verification is bypassed in dev (user auto-verified)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# ── CORS ───────────────────────────────────────────────────
# Space-separated list of allowed origins (pydantic-settings parses JSON arrays too)
CORS_ORIGINS=["http://localhost:5173"]

# ── Dev shortcuts ──────────────────────────────────────────
# If DEV_MODE=true, DEV_USER_EMAIL is auto-logged-in (no auth required)
DEV_MODE=false
DEV_USER_EMAIL=
