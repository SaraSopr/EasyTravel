DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_planner
SECRET_KEY=changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ANTHROPIC_API_KEY=

# ── Google Places (opzionale) ────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
CACHE_TTL_DAYS=30

# ── POI Pipeline classifier ──────────────────────────────
# Usa Anthropic Haiku per la classificazione batch POI
PIPELINE_LLM_BACKEND=anthropic
PIPELINE_LLM_MODEL=claude-haiku-4-5-20251001

# ── Onboarding (esperiences discovery con web search) ────
# Usa Sonnet + tool use per l'onboarding
# Non più configurabile via .env — hardcoded in onboarding.py
# Funziona se ANTHROPIC_API_KEY è configurata

# ── Cloudflare R2 (opzionale) ───────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET_NAME=travel-agent
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Resend (opzionale) ──────────────────────────────────────
# Se assente la verifica email è bypassata in dev (utente auto-verificato)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
